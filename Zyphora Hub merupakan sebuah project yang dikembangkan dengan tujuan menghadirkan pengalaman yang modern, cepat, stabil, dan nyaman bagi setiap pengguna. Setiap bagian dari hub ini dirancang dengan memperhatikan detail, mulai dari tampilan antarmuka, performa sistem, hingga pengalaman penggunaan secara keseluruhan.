local function TeleportToPosition(pos)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp and pos then
        hrp.CFrame = CFrame.new(pos)
        return true
    else
        return false
    end
end

local function ClickLaunchFrame()
    local frame = LocalPlayer.PlayerGui:FindFirstChild("LaunchBtn", true)
    
    if frame and frame:IsA("Frame") and frame.Visible then
        local pos = frame.AbsolutePosition
        local size = frame.AbsoluteSize
        mouse1click(pos.X + size.X/2, pos.Y + size.Y/0.5,6)
        return true
    else
        return false
    end
end

local function GetNearestLaunchZone()
    local char = LocalPlayer.Character
    if not char then return nil end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    
    local nearest = nil
    local nearestDist = math.huge
    local playerPos = hrp.Position
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj.Name == "LaunchZone" then
            local pos = nil
            if obj:IsA("BasePart") then
                pos = obj.Position
            elseif obj:IsA("Model") and obj.PrimaryPart then
                pos = obj.PrimaryPart.Position
            end
            
            if pos then
                local dist = (playerPos - pos).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearest = {object = obj, position = pos}
                end
            end
        end
    end
    
    return nearest
end

local function TeleportToLaunchZone()
    local zone = GetNearestLaunchZone()
    if not zone then return false end
    
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = CFrame.new(zone.position)
        return true
    end
    return false
end

local function FindNearestClaimProxyPrompt()
    local character = LocalPlayer.Character
    if not character then 
        return nil 
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then 
        return nil 
    end
    
    local nearestPrompt = nil
    local nearestDist = math.huge
    local promptPosition = nil
    
    local prompts = Workspace:GetDescendants()
    
    for _, obj in ipairs(prompts) do
        if obj:IsA("ProximityPrompt") and obj.ActionText == "Claim" then
            local pos = nil
            
            if obj.Parent then
                local positionObj = obj.Parent:FindFirstChild("Position")
                if positionObj then
                    pos = positionObj.Position
                elseif obj.Parent:IsA("BasePart") then
                    pos = obj.Parent.Position
                elseif obj.Parent:IsA("Model") then
                    local rootPart = obj.Parent:FindFirstChild("HumanoidRootPart") or obj.Parent:FindFirstChild("Head")
                    if rootPart then
                        pos = rootPart.Position
                    end
                end
            end
            
            if not pos then
                local attachment = obj:FindFirstChild("Attachment")
                if attachment then
                    pos = attachment.WorldPosition
                end
            end
            
            if pos then
                local dist = (hrp.Position - pos).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearestPrompt = obj
                    promptPosition = pos
                end
            end
        end
    end
    
    if nearestPrompt then
        return nearestPrompt, promptPosition, nearestDist
    else
        return nil
    end
end

local function WaitForClaimProxyprompt(timeout)
    timeout = timeout or 10
    
    local startTime = tick()
    
    while tick() - startTime < timeout do
        local prompt, pos = FindNearestClaimProxyPrompt()
        if prompt then
            return prompt, pos
        end
        task.wait(0.5)
    end
    
    return nil
end

local function FireClaimPrompt(prompt)
    if not prompt then return false end
    
    local success, err = pcall(function()
        fireproximityprompt(prompt)
    end)
    
    if success then
        return true
    else
        return false
    end
end

local function ExecuteClaim()
    pcall(function()
        TeleportToLaunchZone()
        task.wait(0.1)
        
        ClickLaunchFrame()
        task.wait(0.3)
        
        task.wait(0.1)
        ClickLaunchFrame()
        
        local prompt, pos = WaitForClaimProxyprompt(math.huge)
        
        if prompt and pos then
            TeleportToPosition(pos)
            task.wait(1)
            
            local firedCount = 0
            local prompts = workspace:GetDescendants()
            
            for _, v in pairs(prompts) do
                if v:IsA("ProximityPrompt") and v.ActionText == "Claim" then
                    local promptPos = nil
                    if v.Parent and v.Parent:IsA("BasePart") then
                        promptPos = v.Parent.Position
                    elseif v.Parent and v.Parent:IsA("Model") and v.Parent.PrimaryPart then
                        promptPos = v.Parent.PrimaryPart.Position
                    end
                    
                    if promptPos then
                        TeleportToPosition(promptPos)
                        task.wait(0.3)
                    end
                    
                    if FireClaimPrompt(v) then
                        firedCount = firedCount + 1
                    end
                    
                    task.wait(0.5)
                end
            end
            
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ProximityPrompt") and v.ActionText == "Claim" then
                    pcall(function()
                        fireproximityprompt(v)
                    end)
                end
            end
        end
    end)
end

