local function TeleportToPosition(pos)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp and pos then
        hrp.CFrame = CFrame.new(pos)
        return true
    end
    return false
end

local function ClickLaunchFrame()
    local frame = LocalPlayer.PlayerGui:FindFirstChild("LaunchBtn", true)
    if frame and frame:IsA("Frame") and frame.Visible then
        pcall(function()
            -- Method 1: Fire semua sinyal yang mungkin
            local Signals = {"Activated", "MouseButton1Down", "MouseButton2Down", "MouseButton1Click", "MouseButton2Click"}
            
            -- Cari semua button di dalam frame
            for _, child in pairs(frame:GetDescendants()) do
                if child:IsA("ImageButton") or child:IsA("TextButton") then
                    for _, signal in pairs(Signals) do
                        pcall(function()
                            firesignal(child[signal])
                        end)
                    end
                end
            end
            
            -- Method 2: Fire touch langsung ke frame
            firetouchstart(frame)
            task.wait(0.05)
            firetouchend(frame)
            
            -- Method 3: VirtualInputManager untuk HP
            local pos = frame.AbsolutePosition
            local size = frame.AbsoluteSize
            local centerX = pos.X + size.X / 2
            local centerY = pos.Y + size.Y / 2
            
            VirtualInputManager:SendTouchInput(true, centerX, centerY, Enum.TouchType.Touch)
            task.wait(0.05)
            VirtualInputManager:SendTouchInput(false, centerX, centerY, Enum.TouchType.Touch)
            
            -- Method 4: UserInputService
            local touchBegin = {
                Position = Vector2.new(centerX, centerY),
                UserInputState = Enum.UserInputState.Begin,
                UserInputType = Enum.UserInputType.Touch
            }
            UserInputService:InputBegan(touchBegin, false)
            task.wait(0.05)
            
            local touchEnd = {
                Position = Vector2.new(centerX, centerY),
                UserInputState = Enum.UserInputState.End,
                UserInputType = Enum.UserInputType.Touch
            }
            UserInputService:InputEnded(touchEnd, false)
            
            -- Method 5: Coba fire click detector
            local clickDetector = frame:FindFirstChild("ClickDetector")
            if clickDetector then
                clickDetector:Click()
            end
            
            -- Method 6: Fire semua proximity prompt
            for _, prompt in pairs(frame:GetDescendants()) do
                if prompt:IsA("ProximityPrompt") then
                    fireproximityprompt(prompt)
                end
            end
        end)
        return true
    end
    return false
end

